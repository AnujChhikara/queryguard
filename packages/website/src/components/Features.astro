---
const rules = [
  {
    id: "n-plus-one",
    title: "N+1 loops",
    body: "A query inside a loop runs once per row — 1 + N round trips. Cardinal flags it and, with a knowledge file, silences the ones that are provably small.",
  },
  {
    id: "unbounded-read",
    title: "Unbounded reads",
    body: "A read with no WHERE and no LIMIT can scan an entire table. Caught before it quietly turns into a full-table load in production.",
  },
  {
    id: "over-fetch",
    title: "Over-fetching",
    body: "Loading a whole large table when a selective subset would do. Cardinal suggests the narrower read from facts you declare about your data.",
  },
];
---

<section class="features" id="what">
  <div class="container">
    <p class="eyebrow">What it catches</p>
    <div class="rows">
      {
        rules.map((r, i) => (
          <article class="row">
            <span class="idx">{String(i + 1).padStart(2, "0")}</span>
            <div class="rule-body">
              <h3>{r.title}</h3>
              <code class="tag">{r.id}</code>
              <p>{r.body}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="promises">
      <div class="promise">
        <h4>Database-aware</h4>
        <p>Not a generic linter — it understands query shape, cardinality, and the cost of a round trip.</p>
      </div>
      <div class="promise">
        <h4>100% static</h4>
        <p>No LLM, no network, no database connection. Analysis runs entirely on your machine.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .features {
    padding-block: clamp(3.5rem, 8vw, 6.5rem);
    border-top: 1.5px solid var(--ink);
  }
  .rows {
    margin-top: 2.5rem;
    display: grid;
    gap: 0;
  }
  .row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1rem, 4vw, 3rem);
    padding-block: 2rem;
    border-top: 1px solid var(--grid);
  }
  .row:first-child {
    border-top: 0;
  }
  .idx {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--muted);
    padding-top: 0.35rem;
  }
  .rule-body h3 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    display: inline-block;
  }
  .tag {
    display: inline-block;
    margin-left: 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    background: var(--marker);
    padding: 0.15em 0.5em;
    border-radius: 4px;
    vertical-align: middle;
  }
  .rule-body p {
    margin-top: 0.7rem;
    max-width: 62ch;
    color: #2b2b28;
  }
  .promises {
    margin-top: 3.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--ink);
    border: 1.5px solid var(--ink);
    border-radius: 12px;
    overflow: hidden;
  }
  .promise {
    background: var(--paper);
    padding: 1.6rem 1.5rem;
  }
  .promise h4 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
  }
  .promise p {
    color: #2b2b28;
    font-size: 0.96rem;
  }

  @media (max-width: 680px) {
    .promises {
      grid-template-columns: 1fr;
    }
  }
</style>
