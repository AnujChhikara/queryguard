---
const repo = "https://github.com/AnujChhikara/cardinal";
const marketplace = "https://marketplace.visualstudio.com/items?itemName=anujchhikara.cardinal-vscode";
---

<header class="header">
  <div class="container bar">
    <a class="wordmark" href="/">Cardinal<span class="tick">▮</span></a>
    <nav class="nav">
      <a class="nav-link section" href="#what">Rules</a>
      <a class="nav-link section" href="#how">How it works</a>
      <a class="nav-link" href={repo}>GitHub</a>
      <a class="nav-cta" href={marketplace}>Install</a>
    </nav>
  </div>
</header>

<style>
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.1rem;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.3rem, 2.4vw, 1.55rem);
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--ink);
  }
  .tick {
    color: var(--marker);
    -webkit-text-stroke: 0.5px var(--ink);
    margin-left: 0.14em;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2vw, 1.7rem);
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--ink);
    padding-bottom: 2px;
    border-bottom: 1.5px solid transparent;
    transition: border-color 0.15s ease;
  }
  .nav-link:hover {
    border-bottom-color: var(--marker);
  }
  .nav-cta {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-decoration: none;
    color: var(--paper);
    background: var(--ink);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1.5px solid var(--ink);
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .nav-cta:hover {
    background: var(--marker);
    color: var(--ink);
  }

  @media (max-width: 620px) {
    .nav-link.section {
      display: none;
    }
  }
</style>
