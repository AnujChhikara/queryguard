---
const repo = "https://github.com/AnujChhikara/cardinal";
const marketplace = "https://marketplace.visualstudio.com/items?itemName=anujchhikara.cardinal-vscode";
const openvsx = "https://open-vsx.org/extension/anujchhikara/cardinal-vscode";

// Rendered with set:html so the braces in the code aren't parsed as Astro expressions.
const codeHtml = `<span class="ln"> </span><span class="kw">const</span> users = <span class="kw">await</span> prisma.user.findMany()
<span class="ln"> </span><span class="kw">for</span> (<span class="kw">const</span> user <span class="kw">of</span> users) {
<span class="ln"> </span>  <span class="kw">await</span> <span class="hl squig">prisma.post.findMany({ where: { authorId: user.id } })</span>
<span class="ln"> </span>}`;
---

<section class="hero">
  <div class="container grid">
    <div class="copy">
      <p class="eyebrow" data-hero-item>Static database linter · TypeScript &amp; JavaScript</p>
      <h1 class="headline" data-hero-item>
        Spot the query your ORM<br /> quietly runs
        <span class="mark">10,000 times</span>.
      </h1>
      <p class="sub" data-hero-item>
        The slow queries you'd catch in code review - N+1 loops, unbounded reads,
        over-fetching - caught automatically as you type. 100% static: no LLM, no
        database connection.
      </p>
      <div class="actions" data-hero-item>
        <a class="btn btn--primary" href={marketplace}>
          Install for VS&nbsp;Code
          <span aria-hidden="true">→</span>
        </a>
        <a class="btn" href={repo}>View on GitHub</a>
      </div>
      <a class="soon soon--link" href={openvsx} data-hero-item>Also on Open&nbsp;VSX - Cursor &amp; VSCodium →</a>
      <button
        class="install"
        data-hero-item
        type="button"
        data-copy="npm i -D cardinal-cli"
        aria-label="Copy install command"
      >
        <span class="cmd"><span class="dollar">$</span> npm i -D cardinal-cli</span>
        <span class="copy-icon" aria-hidden="true">
          <svg class="ic copy" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="12" height="12" rx="2" /><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
          </svg>
          <svg class="ic check" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5" />
          </svg>
        </span>
      </button>
    </div>

    <div class="card-wrap" data-hero-item>
      <div class="glow" aria-hidden="true"></div>
      <figure class="card" aria-label="A Cardinal N+1 diagnostic on a Prisma query">
        <figcaption class="chrome">
          <span class="d"></span><span class="d"></span><span class="d"></span>
          <span class="file">users.service.ts</span>
        </figcaption>
        <pre class="code"><code set:html={codeHtml} /></pre>
        <div class="diag">
          <span class="sev">error</span>
          <span class="rule">n-plus-one</span>
          <span class="msg">Query on “post” runs once per user - batch it into one query.</span>
        </div>
      </figure>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-copy]").forEach((btn) => {
    let timer: ReturnType<typeof setTimeout>;
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy") || "";
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        return;
      }
      btn.classList.add("copied");
      clearTimeout(timer);
      timer = setTimeout(() => btn.classList.remove("copied"), 1600);
    });
  });
</script>

<style>
  .hero {
    padding-block: clamp(3.5rem, 9vw, 7rem);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .headline {
    font-size: clamp(2.5rem, 6.3vw, 5rem);
    margin-top: 1.4rem;
  }
  .sub {
    max-width: 34ch;
    margin-top: 1.6rem;
    color: #2b2b28;
    font-size: 1.06rem;
  }
  .actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem 1.35rem;
    margin-top: 2.2rem;
  }
  .soon {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .soon--link {
    display: inline-block;
    margin-top: 1.4rem;
    text-decoration: none;
    border-bottom: 1.5px solid var(--marker);
    padding-bottom: 2px;
  }
  .soon--link:hover {
    color: var(--ink);
  }
  .install {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    margin-top: 1.4rem;
    padding: 0.55rem 0.7rem 0.55rem 0.95rem;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    background: var(--ink);
    color: var(--paper);
    border: 0;
    border-radius: 8px;
    cursor: pointer;
  }
  .install .dollar {
    color: var(--marker);
    margin-right: 0.5rem;
    user-select: none;
  }
  .copy-icon {
    display: inline-flex;
    color: #8a8a85;
    transition: color 0.15s ease;
  }
  .install:hover .copy-icon {
    color: var(--paper);
  }
  .ic.check {
    display: none;
  }
  .install.copied .copy-icon {
    color: var(--marker);
  }
  .install.copied .ic.copy {
    display: none;
  }
  .install.copied .ic.check {
    display: inline;
  }

  /* ---- diagnostic card ---- */
  .card-wrap {
    position: relative;
  }
  .glow {
    position: absolute;
    inset: 8% 6%;
    background: var(--marker);
    filter: blur(80px);
    opacity: 0.55;
    z-index: 0;
  }
  .card {
    position: relative;
    z-index: 1;
    margin: 0;
    background: #0d0d0d;
    color: #f4f4f0;
    border: 1.5px solid var(--ink);
    border-radius: 14px;
    box-shadow: 10px 12px 0 var(--ink);
    overflow: hidden;
  }
  .chrome {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 0.95rem;
    border-bottom: 1px solid #262625;
  }
  .chrome .d {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #3a3a38;
  }
  .file {
    margin-left: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #8a8a85;
  }
  .code {
    margin: 0;
    padding: 1.2rem 1.25rem 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.85;
    white-space: pre;
    overflow-x: auto;
  }
  .code .kw {
    color: #b9b9b3;
  }
  .code .ln {
    color: #55554f;
    user-select: none;
  }
  .hl {
    background: var(--marker);
    color: var(--ink);
    border-radius: 3px;
    padding: 0.1em 0.15em;
  }
  .squig {
    text-decoration: underline wavy var(--red);
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
  }
  .diag {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem 0.7rem;
    padding: 0.95rem 1.25rem 1.15rem;
    border-top: 1px solid #262625;
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }
  .sev {
    color: var(--red);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .rule {
    color: var(--marker);
  }
  .msg {
    color: #b7b7b1;
    flex: 1 1 14ch;
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .card-wrap {
      order: 2;
    }
  }
</style>
