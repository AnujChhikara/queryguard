---
const repo = "https://github.com/AnujChhikara/cardinal";
const marketplace = "https://marketplace.visualstudio.com/items?itemName=anujchhikara.cardinal-vscode";
const creator = "https://anujchhikara.com";
---

<footer class="footer">
  <div class="container inner">
    <div class="cta">
      <h2>Stop shipping the 10,000-query loop.</h2>
      <div class="cta-actions">
        <a class="btn btn--primary" href={marketplace}>
          Install for VS&nbsp;Code
          <span aria-hidden="true">→</span>
        </a>
        <a class="btn btn--ghost" href={repo}>View on GitHub</a>
      </div>
    </div>
    <div class="fine">
      <span class="mono">Cardinal</span>
      <span class="links">
        <a href={repo}>GitHub</a>
        <a href={`${repo}/issues/new/choose`}>Report a wrong finding</a>
        <a href={`${repo}/blob/main/LICENSE`}>MIT</a>
      </span>
      <span class="mono muted">Built by <a class="creator" href={creator}>Anuj&nbsp;Chhikara</a></span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: var(--paper);
    padding-block: clamp(3rem, 7vw, 5rem);
  }
  .cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid #2a2a28;
  }
  .cta h2 {
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    max-width: 16ch;
  }
  /* Invert the primary button on the dark footer. */
  .footer .btn--primary {
    background: var(--marker);
    color: var(--ink);
    border-color: var(--marker);
  }
  .footer .btn--primary:hover {
    background: var(--paper);
    border-color: var(--paper);
  }
  .cta-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.9rem;
  }
  .footer .btn--ghost {
    border-color: var(--paper);
    color: var(--paper);
  }
  .footer .btn--ghost:hover {
    background: var(--paper);
    color: var(--ink);
  }
  .fine {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .links {
    display: flex;
    gap: 1.3rem;
  }
  .links a {
    text-decoration: none;
    border-bottom: 1.5px solid var(--marker);
  }
  .muted {
    color: #8a8a85;
  }
  .creator {
    color: var(--paper);
    text-decoration: none;
    border-bottom: 1.5px solid var(--marker);
  }
  .creator:hover {
    background: var(--marker);
    color: var(--ink);
  }
</style>
