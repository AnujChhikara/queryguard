---
const items = [
  { s: "shipped", t: "Schema-awareness for Prisma: unindexed-query reads @id / @unique / @@index straight from schema.prisma" },
  { s: "shipped", t: "Config file, a real SQL parser, and the VS Code Marketplace + Open VSX" },
  { s: "shipped", t: "Context-aware over-fetch & cardinality across Drizzle, Mongoose, TypeORM, and raw SQL" },
  { s: "shipped", t: "TypeORM adapter and machine-readable --format json output for AI agents" },
  { s: "next", t: "Index extraction for Drizzle, TypeORM, and Mongoose - unindexed-query beyond Prisma" },
  { s: "next", t: "More parser-backed SQL rules: subqueries, HAVING / GROUP BY misuse, SELECT *" },
  { s: "later", t: "More engines (MySQL, Postgres, PlanetScale) and layers (Kysely, Sequelize)" },
  { s: "explore", t: "Deep mode: cross-module data-flow checks" },
];
---

<section class="roadmap" id="next">
  <div class="container">
    <p class="eyebrow" data-reveal>What's next</p>
    <h2 class="title" data-reveal>Early, and moving.</h2>
    <p class="tuned" data-reveal>
      Tuned by real codebases: every wrong finding you
      <a href="https://github.com/AnujChhikara/cardinal/issues/new/choose">report</a>
      becomes a permanent test. Fixed once, fixed forever.
    </p>
    <ul class="list">
      {
        items.map((i) => (
          <li data-reveal>
            <span class={`badge badge--${i.s}`}>{i.s}</span>
            <span class="text">{i.t}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .roadmap {
    padding-block: clamp(3.5rem, 8vw, 6.5rem);
  }
  .title {
    margin-top: 1.2rem;
    font-size: clamp(1.9rem, 4.4vw, 3.1rem);
  }
  .tuned {
    margin-top: 1.4rem;
    max-width: 52ch;
    color: #2b2b28;
    font-size: 1.02rem;
  }
  .tuned a {
    border-bottom: 1.5px solid var(--marker);
    text-decoration: none;
  }
  .list {
    margin: 2.4rem 0 0;
    padding: 0;
    list-style: none;
  }
  .list li {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding-block: 1.05rem;
    border-top: 1px solid var(--grid);
  }
  .list li:first-child {
    border-top: 0;
  }
  .badge {
    flex: none;
    width: 5.5rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25em 0;
    border-radius: 999px;
    border: 1.5px solid var(--ink);
  }
  .badge--shipped {
    background: var(--ink);
    color: var(--paper);
  }
  .badge--next {
    background: var(--marker);
  }
  .badge--later {
    background: var(--paper);
  }
  .badge--explore {
    background: var(--paper);
    border-style: dashed;
    color: var(--muted);
  }
  .text {
    font-size: 1.02rem;
  }

  @media (max-width: 560px) {
    .list li {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
