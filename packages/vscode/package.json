{
  "name": "cardinal-vscode",
  "displayName": "Cardinal",
  "description": "A database-aware linter for TypeScript/JavaScript. Flags N+1 loops, unbounded reads, and over-fetching as you type — 100% static.",
  "version": "0.1.0",
  "publisher": "anujchhikara",
  "license": "MIT",
  "categories": ["Linters", "Programming Languages"],
  "keywords": ["n+1", "prisma", "drizzle", "mongoose", "sql", "database", "linter"],
  "homepage": "https://github.com/AnujChhikara/cardinal#readme",
  "repository": { "type": "git", "url": "https://github.com/AnujChhikara/cardinal" },
  "bugs": { "url": "https://github.com/AnujChhikara/cardinal/issues" },
  "engines": { "vscode": "^1.85.0" },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "configuration": {
      "title": "Cardinal",
      "properties": {
        "cardinal.useKnowledge": {
          "type": "boolean",
          "default": true,
          "description": "Use a discovered cardinal.knowledge.yaml file to make diagnostics scale-aware (silence provably-small loops, escalate provably-large fan-out, and flag over-fetching)."
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "package": "tsup && vsce package --no-dependencies -o cardinal.vsix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cardinal/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
