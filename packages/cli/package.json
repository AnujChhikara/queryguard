{
  "name": "cardinal-cli",
  "version": "0.1.3",
  "description": "Cardinal CLI — a static, database-aware linter for TypeScript/JavaScript. Flags N+1 loops, unbounded reads, and over-fetching, with a CI-friendly exit code.",
  "keywords": ["linter", "cli", "n+1", "prisma", "drizzle", "mongoose", "sql", "database", "ci"],
  "license": "MIT",
  "homepage": "https://github.com/AnujChhikara/cardinal#readme",
  "repository": { "type": "git", "url": "git+https://github.com/AnujChhikara/cardinal.git", "directory": "packages/cli" },
  "bugs": { "url": "https://github.com/AnujChhikara/cardinal/issues" },
  "type": "module",
  "bin": { "cardinal": "./dist/bin.js" },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=18" },
  "scripts": {
    "test": "vitest run",
    "build": "tsup src/bin.ts --format esm",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cardinal-core": "workspace:*",
    "fast-glob": "^3.3.0"
  }
}
