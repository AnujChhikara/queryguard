{
  "name": "cardinal-core",
  "version": "0.1.3",
  "description": "Static, database-aware analysis engine for TypeScript/JavaScript — detects N+1 loops, unbounded reads, and over-fetching. Powers the Cardinal CLI and VS Code extension.",
  "keywords": [
    "linter",
    "static-analysis",
    "n+1",
    "prisma",
    "drizzle",
    "mongoose",
    "sql",
    "database",
    "ts-morph"
  ],
  "license": "MIT",
  "homepage": "https://github.com/AnujChhikara/cardinal#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnujChhikara/cardinal.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/AnujChhikara/cardinal/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "node-sql-parser": "^5.4.0",
    "ts-morph": "^23.0.0",
    "yaml": "^2.9.0"
  }
}
